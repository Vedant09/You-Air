# Backend environment variables
PORT=3000
FRONTEND_URL=http://localhost:4200

# For production Railway deployment:
# FRONTEND_URL=https://your-frontend-railway-url.railway.app

# Optional: free account at opensky-network.org
# Without these the shared anonymous IP quota returns states=null when throttled.
# With credentials your account gets its own quota.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Other services need no keys:
#   MapLibre GL JS   (open source, free)
#   CARTO dark tiles (free, no key)
#   Nominatim / OSM  (free reverse geocoding)
